generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Order {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  date        DateTime  @db.DateTime(0)
  description String?   @db.Text
  products    Product[]

  @@map("orders")
}

model Product {
  id             Int      @id @default(autoincrement())
  serialNumber   String?  @map("serial_number") @db.VarChar(64)
  isNew          Int      @default(1) @map("is_new") @db.TinyInt
  photo          String?  @db.VarChar(255)
  title          String   @db.VarChar(255)
  type           String?  @db.VarChar(128)
  specification  String?  @db.VarChar(255)
  guaranteeStart DateTime? @map("guarantee_start") @db.DateTime(0)
  guaranteeEnd   DateTime? @map("guarantee_end") @db.DateTime(0)
  orderId        Int?     @map("order_id")
  date           DateTime? @db.DateTime(0)
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  prices         Price[]

  @@map("products")
}

model Price {
  id        Int     @id @default(autoincrement())
  productId Int?    @map("product_id")
  value     Decimal @db.Decimal(12, 2)
  symbol    String  @db.VarChar(8)
  isDefault Int     @default(0) @map("is_default") @db.TinyInt
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("prices")
}
